                ${isDark ? 'bg-emerald-900/50 text-emerald-400' : 'bg-white text-emerald-600 shadow-sm'}
              `}>
                <suggestedMethod.icon className="w-6 h-6" />
                <span className="absolute -top-1 -right-1 flex h-3.5 w-3.5">
                  <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span className={`relative inline-flex rounded-full h-3.5 w-3.5 bg-emerald-500 border-2 ${isDark ? 'border-zinc-950' : 'border-emerald-50'}`}></span>
                </span>
              </div>
              
              <div className="flex flex-col">
                <div className="flex items-center gap-2 mb-1">
                  <h2 className={`text-base sm:text-lg font-bold ${isDark ? 'text-emerald-50' : 'text-emerald-950'}`}>
                    {suggestedMethod.title}
                  </h2>
                </div>
                <p className={`text-xs sm:text-sm font-medium ${isDark ? 'text-emerald-200/70' : 'text-emerald-700/80'}`}>
