        <a 
          href="https://AMT-IR.github.io" 
          target="_blank" 
          rel="noreferrer"
          className={`flex items-center gap-1.5 text-sm font-bold transition-colors hover:text-emerald-500 ${theme.textMain}`}
        >
          <ExternalLink className="w-4 h-4" />
          <span>پورتال جامع AMT-IR</span>
        </a>
      </footer>

    </div>
  );
