            `}>
              <CheckCircle2 className="w-3.5 h-3.5" />
              پیشنهاد ما
            </div>
          </div>

          <div className="flex items-center gap-2">
            <Clock className={`w-4 h-4 ${isDark ? 'text-emerald-400/80' : 'text-emerald-600'}`} />
            <span className={`text-xs font-bold ${isDark ? 'text-emerald-300' : 'text-emerald-700'}`}>
              {suggestedMethod.time}
            </span>
          </div>

          {/* دکمه بزرگ کارت ویژه */}
          <a 
            href={suggestedMethod.link} 
            target="_blank" 
            rel="noreferrer"
            className={`w-full py-3.5 rounded-xl flex items-center justify-center gap-2 text-sm font-bold transition-transform active:scale-[0.98]
              ${isDark ? 'bg-emerald-500 hover:bg-emerald-600 text-white shadow-[0_0_20px_rgba(16,185,129,0.3)]' : 'bg-emerald-600 hover:bg-emerald-700 text-white shadow-md'}
            `}
          >
            {suggestedMethod.btnText}
            <ArrowLeft className="w-4 h-4" />
          </a>
        </div>


        {/* لیست سایر روش‌ها */}
        <div className="flex flex-col gap-3 pb-8">
          <h3 className={`text-xs font-bold px-2 mb-1 ${theme.textSub}`}>سایر روش‌های ارتباطی</h3>
          
          {regularMethods.map((method) => (
            <div 
              key={method.id}
              className={`w-full rounded-[20px] border glass-base p-3 flex items-center justify-between gap-2 transition-colors ${theme.card} ${theme.cardHover}`}
            >
              {/* بخش سمت راست (آیکون و متن) */}
              <div className="flex items-center gap-3 overflow-hidden">
                <div className={`w-10 h-10 rounded-[14px] flex items-center justify-center flex-shrink-0 ${theme.iconBg}`}>
                  <method.icon className="w-5 h-5" />
                </div>
                
                <div className="flex flex-col truncate pr-1">
                  <h4 className={`text-sm font-bold truncate ${theme.textMain}`}>
                    {method.title}
                  </h4>
                  <div className={`flex items-center gap-1.5 text-[11px] mt-0.5 ${theme.textSub}`}>
