    iconBg: isDark ? 'bg-zinc-800/50 text-zinc-300' : 'bg-zinc-100 text-zinc-600',
    headerFooter: isDark ? 'bg-zinc-950/40 border-zinc-800/50' : 'bg-white/40 border-zinc-200/50',
